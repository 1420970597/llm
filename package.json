{
  "name": "llm-data-factory",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web-user"
  ],
  "scripts": {
    "build": "npm run build -w apps/web-user",
    "dev:web": "npm run dev -w apps/web-user",
    "compose:config": "docker compose -f deployments/compose/docker-compose.yml config",
    "compose:up": "docker compose -f deployments/compose/docker-compose.yml up -d --build",
    "compose:down": "docker compose -f deployments/compose/docker-compose.yml down",
    "compose:logs": "docker compose -f deployments/compose/docker-compose.yml logs -f",
    "docker:prune-build-cache": "docker builder prune -af"
  }
}
